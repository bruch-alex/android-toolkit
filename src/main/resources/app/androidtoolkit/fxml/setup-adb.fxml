<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.Card?>
<?import atlantafx.base.layout.InputGroup?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.androidtoolkit.controller.SetupScreenController">

    <VBox spacing="16"
          alignment="CENTER"
          AnchorPane.topAnchor="20"
          maxWidth="700"
          prefWidth="700"
          fillWidth="false"
          AnchorPane.bottomAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20">

        <Card>
            <body>
                <VBox spacing="12" alignment="CENTER">

                    <InputGroup>
                        <TextField fx:id="customAdbPathTextField"
                                   promptText="Android SDK or adb path"/>

                        <Button fx:id="setPathButton"
                                text="Browse"/>
                    </InputGroup>

                    <Label fx:id="adbStatusLabel"
                           text="ADB not found"/>

                    <Button fx:id="startButton" text="Start"/>
                </VBox>
            </body>
        </Card>

        <Card>
            <body>
                <VBox spacing="12" alignment="CENTER">
                    <Label text="Device not connected"/>
                </VBox>
            </body>
        </Card>


    </VBox>
</AnchorPane>
