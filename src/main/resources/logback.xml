<configuration>

    <appender name="FILE"
              class="ch.qos.logback.core.FileAppender">

        <file>app.log</file>

        <encoder>
            <pattern>
                %d %-5level %logger - %msg%n
            </pattern>
        </encoder>
    </appender>

    <root level="DEBUG">
        <appender-ref ref="FILE"/>
    </root>

</configuration>